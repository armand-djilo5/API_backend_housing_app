// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}



model user{
  id               String @id @default(uuid()) @map("_id")
  name             String 
  email            String @unique
  password         String
  role             Role @default(TENANT)
  phone            String
  refreshToken     String?
  createAt         DateTime @default(now())


  listings         listing[]   @relation("landlordListings")

}
enum Role{
  TENANT
  LANDLORD
  ADMIN
}

model listing {
  id               String @id @default(uuid()) @map("_id")
  title            String
  description      String
  price            Float
  currency         String @default("XAF")
  propertyType     PropertyType
  bedrooms         Int
  bathrooms        Int
  areaSqm          Float
  amenities        String[]
  images           String[]
  loction          Location
  status           ListingStatus   @default(ACTIVE)
  landlordId       String    
  landlord         user @relation("landlordListings", fields: [landlordId] , references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  }

  type Location {
    address      String
    city         String
    region       String
    country      String
    lat          Float?
    lng          Float?
  }

  enum  PropertyType {
    APARTMENT
    STUDIO
    HOUSE
    ROOM
    DUPLEX
  }

  enum ListingStatus {
    ACTIVE
    RENTED
    INACTIVE
  }
