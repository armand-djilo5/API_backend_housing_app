// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}



model user{
  id               String @id @default(uuid()) @map("_id")
  name             String 
  email            String @unique
  password         String
  role             Role @default(TENANT)
  phone            String
  refreshToken     String?
  createAt         DateTime @default(now())


  listings         listing[]   @relation("landlordListings")
  favorites        favorite[]
  inquiries        inquiry[]  @relation("tenantInquiries")

}
enum Role{
  TENANT
  LANDLORD
  ADMIN
}

model listing {
  id               String @id @default(uuid()) @map("_id")
  title            String
  description      String
  price            Float
  currency         String @default("XAF")
  propertyType     PropertyType
  bedrooms         Int
  bathrooms        Int
  areaSqm          Float
  amenities        String[]
  images           String[]
  location         Location
  status           ListingStatus   @default(ACTIVE)
  landlordId       String    
  landlord         user @relation("landlordListings", fields: [landlordId] , references: [id], onDelete:Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  favorites        favorite[]
  inquiries        inquiry[]
  }

  type Location {
    address      String
    city         String
    region       String
    country      String
    lat          Float?
    lng          Float?
  }

  enum  PropertyType {
    APARTMENT
    STUDIO
    HOUSE
    ROOM
    DUPLEX
  }

  enum ListingStatus {
    ACTIVE
    RENTED
    INACTIVE
  }

  model favorite{
    id          String @id @default(uuid()) @map("_id")
    userId      String
    listingId   String 
    user        user @relation(fields: [userId], references: [id], onDelete:Cascade)
    listing     listing @relation(fields: [listingId], references: [id], onDelete:Cascade)
    creatAt     DateTime @default(now())

    @@unique([userId, listingId])
  }

  model inquiry{
    id          String @id @default(uuid()) @map("_id")
    tenantId    String
    listingId   String
    message     String
    status      inquiryStatus  @default(PENDING)
    tenant      user  @relation("tenantInquiries", fields: [tenantId] , references: [id], onDelete:Cascade)
    listing     listing  @relation(fields: [listingId], references: [id], onDelete:Cascade)
    creatAt     DateTime   @default(now())


  }

  enum    inquiryStatus{
    PENDING
    RESPONDED
    CLOSED
  }
